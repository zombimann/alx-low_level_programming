#include <stdio.h>

/**
 * rev_string - reverses a string
 * @s: the input string
 *
 * Return: nothing
 */

void rev_string(char *s)
{
	int n, i;
	char *temp;

	n = 0;
	while (*s != '\0')
	{
		s++;
		n++;
	}

	while (--n >= 0)
		*temp++ = *(--s);
	while (--n >= 0)
		--temp;
	while(--n >= 0)
		*(s++) = *(temp++);

	printf("%s\n", temp);
}
