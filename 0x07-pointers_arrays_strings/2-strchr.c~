#include <stdio.h>

/**
 * _strchr - locate a character in a string
 * @s: The input string
 * @c: The character to be found
 *
 * Return: a pointer to the first occurence of c in the string, or NULL if not found
 */

char *_strchr(char *s, char c)
{
	while (*s != '\0')
		if (*(++s) == c)
			return (s);
	return (NULL);
}
