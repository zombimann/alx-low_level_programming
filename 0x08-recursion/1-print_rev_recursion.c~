#include "main.h"

/**
 * _print_rev_recursion - prints a string followed by a newline
 * @s: the input string to be printed
 *
 * Return: nothing
 */

void _print_rev_recursion(char *s)
{
	print (s);
	_putchar ('\n');
}

/**
 * print - does the actual printing and uses recursion
 * @s: The string to be printed
 *
 * Return: nothing
 */

void print(char *s)
{
	int n;

	n = 0;
	while (*s++ != '\0')
		n++;
	if (n-- <= 0)
		return;
	_putchar(*s--);
	print(s--);
}
